generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = []
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid()) @db.VarChar(36)
  userId              String              @unique @db.VarChar(20)
  password            String              @db.VarChar(255)
  nickname            String              @unique @db.VarChar(10)
  profileImg          String?             @db.VarChar(255)
  createdAt           DateTime?           @default(now()) @db.Timestamp(0)
  totalStudyTime      Int                 @default(0)
  chatMessages        ChatMessage[]       @relation("UserToChatMessage")
  friendsFrom         Friend[]            @relation("FriendToUser")
  friendsTo           Friend[]            @relation("UserToFriend")
  refreshTokens       RefreshToken[]
  ownedRooms          Room[]              @relation("RoomOwner")
  receivedRoomInvites RoomInvite[]        @relation("InviteeToRoomInvite")
  sentRoomInvites     RoomInvite[]        @relation("InviterToRoomInvite")
  roomParticipations  RoomParticipation[]
  schedules           Schedule[]
  timeLogs            TimeLog[]

  @@map("user")
}

model Room {
  id           String              @id @default(cuid()) @db.VarChar(36)
  name         String              @db.VarChar(50)
  createdAt    DateTime?           @default(now()) @db.Timestamp(0)
  ownerCuid    String
  chatMessages ChatMessage[]       @relation("RoomToChatMessage")
  owner        User                @relation("RoomOwner", fields: [ownerCuid], references: [id], onDelete: Cascade)
  invites      RoomInvite[]
  participants RoomParticipation[]
  timeLogs     TimeLog[]

  @@index([ownerCuid], map: "room_ownerCuid_fkey")
  @@map("room")
}

model RoomParticipation {
  userCuid String
  roomCuid String
  joinedAt DateTime @default(now()) @db.Timestamp(0)
  room     Room     @relation(fields: [roomCuid], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userCuid], references: [id], onDelete: Cascade)

  @@id([userCuid, roomCuid])
  @@index([roomCuid], map: "room_participation_roomCuid_fkey")
  @@map("room_participation")
}

model Schedule {
  id        String         @id @default(cuid()) @db.VarChar(36)
  title     String         @db.VarChar(50)
  startTime DateTime?      @db.DateTime(0)
  endTime   DateTime?      @db.DateTime(0)
  status    ScheduleStatus @default(대기중)
  createdAt DateTime?      @default(now()) @db.Timestamp(0)
  order     Int            @default(0)
  userCuid  String
  date      String         @db.VarChar(20)
  user      User           @relation(fields: [userCuid], references: [id], onDelete: Cascade)

  @@index([userCuid], map: "schedule_userCuid_fkey")
  @@map("schedule")
}

model TimeLog {
  id        String    @id @default(cuid()) @db.VarChar(36)
  totalTime Int
  date      DateTime  @db.Date
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  roomCuid  String?
  userCuid  String
  room      Room?     @relation(fields: [roomCuid], references: [id], onDelete: SetNull)
  user      User      @relation(fields: [userCuid], references: [id], onDelete: Cascade)

  @@index([roomCuid])
  @@index([userCuid], map: "time_log_userCuid_fkey")
  @@map("time_log")
}

model Friend {
  friendCuid String
  userCuid   String
  status     FriendStatus @default(pending)
  friend     User         @relation("FriendToUser", fields: [friendCuid], references: [id], onDelete: Cascade)
  user       User         @relation("UserToFriend", fields: [userCuid], references: [id], onDelete: Cascade)

  @@id([userCuid, friendCuid])
  @@index([friendCuid], map: "friend_friendCuid_fkey")
  @@map("friend")
}

model RefreshToken {
  id        String   @id @default(cuid()) @db.VarChar(36)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @db.DateTime(0)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  userCuid  String
  user      User     @relation(fields: [userCuid], references: [id], onDelete: Cascade)

  @@index([userCuid], map: "refresh_token_userCuid_fkey")
  @@map("refresh_token")
}

model RoomInvite {
  id          String           @id @default(cuid()) @db.VarChar(36)
  roomCuid    String
  inviterCuid String
  inviteeCuid String
  status      RoomInviteStatus @default(pending)
  createdAt   DateTime         @default(now()) @db.Timestamp(0)
  updatedAt   DateTime         @updatedAt @db.Timestamp(0)
  invitee     User             @relation("InviteeToRoomInvite", fields: [inviteeCuid], references: [id], onDelete: Cascade)
  inviter     User             @relation("InviterToRoomInvite", fields: [inviterCuid], references: [id], onDelete: Cascade)
  room        Room             @relation(fields: [roomCuid], references: [id], onDelete: Cascade)

  @@unique([roomCuid, inviteeCuid])
  @@index([inviteeCuid], map: "room_invite_inviteeCuid_fkey")
  @@index([inviterCuid], map: "room_invite_inviterCuid_fkey")
  @@index([roomCuid], map: "room_invite_roomCuid_fkey")
  @@map("room_invite")
}

model ChatMessage {
  id          String          @id @default(cuid()) @db.VarChar(36)
  content     String          @db.Text
  userCuid    String
  roomCuid    String
  messageType ChatMessageType @default(message)
  createdAt   DateTime        @default(now()) @db.Timestamp(0)
  room        Room            @relation("RoomToChatMessage", fields: [roomCuid], references: [id], onDelete: Cascade)
  user        User            @relation("UserToChatMessage", fields: [userCuid], references: [id], onDelete: Cascade)

  @@index([roomCuid, createdAt], map: "chat_message_room_time_idx")
  @@index([userCuid], map: "chat_message_userCuid_fkey")
  @@map("chat_message")
}

enum RoomInviteStatus {
  pending
  accepted
  declined
}

enum FriendStatus {
  pending
  accepted
}

enum ScheduleStatus {
  대기중
  진행중
  완료
  취소
}

enum ChatMessageType {
  message
  system
}
