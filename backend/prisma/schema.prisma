generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = []
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid()) @db.VarChar(36)
  userId         String         @unique @db.VarChar(20)
  password       String         @db.VarChar(255)
  nickname       String         @unique @db.VarChar(10)
  profileImg     String?        @db.VarChar(255)
  createdAt      DateTime?      @default(now()) @db.Timestamp(0)
  totalStudyTime Int            @default(0)
  friendsFrom    Friend[]       @relation("FriendToUser") // 친구 요청을 받은 유저들
  friendsTo      Friend[]       @relation("UserToFriend") // 내가 친구 요청을 한 유저들
  refreshTokens  RefreshToken[]
  schedules      Schedule[]
  timeLogs       TimeLog[]
  roomParticipations RoomParticipation[] // 참여한 방들
  ownedRooms     Room[]         @relation("RoomOwner") // 소유한 방들
  sentRoomInvites    RoomInvite[]   @relation("InviterToRoomInvite") // 보낸 방 초대들
  receivedRoomInvites RoomInvite[]  @relation("InviteeToRoomInvite") // 받은 방 초대들

  @@map("user")
}

model Room {
  id        String    @id @default(cuid()) @db.VarChar(36)
  name      String    @db.VarChar(50)
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  ownerCuid String
  owner     User      @relation("RoomOwner", fields: [ownerCuid], references: [id], onDelete: Cascade)
  participants RoomParticipation[] // 참여자들
  timeLogs  TimeLog[]
  invites   RoomInvite[] // 방 초대들

  @@index([ownerCuid], map: "room_ownerCuid_fkey")
  @@map("room")
}

model RoomParticipation {
  userCuid  String
  roomCuid  String
  joinedAt  DateTime @default(now()) @db.Timestamp(0)
  user      User     @relation(fields: [userCuid], references: [id], onDelete: Cascade)
  room      Room     @relation(fields: [roomCuid], references: [id], onDelete: Cascade)

  @@id([userCuid, roomCuid])
  @@index([roomCuid], map: "room_participation_roomCuid_fkey")
  @@map("room_participation")
}

model Schedule {
  id        String         @id @default(cuid()) @db.VarChar(36)
  title     String         @db.VarChar(50)
  startTime DateTime?      @db.DateTime(0)
  endTime   DateTime?      @db.DateTime(0)
  status    ScheduleStatus @default(대기중)
  createdAt DateTime?      @default(now()) @db.Timestamp(0)
  order     Int            @default(0)
  userCuid  String
  date      String         @db.VarChar(20)
  user      User           @relation(fields: [userCuid], references: [id], onDelete: Cascade)

  @@index([userCuid], map: "schedule_userCuid_fkey")
  @@map("schedule")
}

model TimeLog {
  id        String    @id @default(cuid()) @db.VarChar(36)
  totalTime Int // 공부 시간(분 단위)
  date      DateTime  @db.Date
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  roomCuid  String
  userCuid  String
  room      Room      @relation(fields: [roomCuid], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userCuid], references: [id], onDelete: Cascade)

  @@index([roomCuid])
  @@index([userCuid], map: "time_log_userCuid_fkey")
  @@map("time_log")
}

model Friend {
  friendCuid String // 수신자(친구 요청을 받은 유저)
  userCuid   String // 요청자(친구 요청을 한 유저)
  status     FriendStatus @default(pending)
  friend     User         @relation("FriendToUser", fields: [friendCuid], references: [id], onDelete: Cascade)
  user       User         @relation("UserToFriend", fields: [userCuid], references: [id], onDelete: Cascade)

  @@id([userCuid, friendCuid])
  @@index([friendCuid], map: "friend_friendCuid_fkey")
  @@map("friend")
}

model RefreshToken {
  id        String   @id @default(cuid()) @db.VarChar(36)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @db.DateTime(0)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  userCuid  String
  user      User     @relation(fields: [userCuid], references: [id], onDelete: Cascade)

  @@index([userCuid], map: "refresh_token_userCuid_fkey")
  @@map("refresh_token")
}

model RoomInvite {
  id         String            @id @default(cuid()) @db.VarChar(36)
  roomCuid   String
  inviterCuid String           // 초대를 보낸 사용자
  inviteeCuid String           // 초대를 받은 사용자
  status     RoomInviteStatus  @default(pending)
  createdAt  DateTime          @default(now()) @db.Timestamp(0)
  updatedAt  DateTime          @updatedAt @db.Timestamp(0)
  
  room       Room              @relation(fields: [roomCuid], references: [id], onDelete: Cascade)
  inviter    User              @relation("InviterToRoomInvite", fields: [inviterCuid], references: [id], onDelete: Cascade)
  invitee    User              @relation("InviteeToRoomInvite", fields: [inviteeCuid], references: [id], onDelete: Cascade)

  @@unique([roomCuid, inviteeCuid]) // 같은 방에 같은 사용자를 중복 초대 방지
  @@index([inviteeCuid], map: "room_invite_inviteeCuid_fkey")
  @@index([inviterCuid], map: "room_invite_inviterCuid_fkey")
  @@index([roomCuid], map: "room_invite_roomCuid_fkey")
  @@map("room_invite")
}

enum RoomInviteStatus {
  pending
  accepted
  declined
}

enum FriendStatus {
  pending
  accepted
}

enum ScheduleStatus {
  대기중
  진행중
  완료
  취소
}
