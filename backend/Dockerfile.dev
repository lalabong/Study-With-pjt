# 개발용 Dockerfile
FROM node:22-alpine

# 작업 디렉토리 설정
WORKDIR /app

# 패키지 파일 복사
COPY package*.json ./
COPY prisma ./prisma

# 의존성 설치 (개발 의존성 포함)
RUN npm ci

# Prisma 클라이언트 생성
RUN npx prisma generate

# 포트 노출
EXPOSE 4000

# 헬스 체크 추가
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:4000/health || exit 1

# Migration 적용 후 개발 서버 실행 (tsx watch 사용)
CMD ["sh", "-c", "npx prisma migrate deploy && npm run dev"]
