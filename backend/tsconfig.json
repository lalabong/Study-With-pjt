{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "#root/*": ["./index.ts"],
      "#src/*": ["./src/*.ts"],
      "#lib/*": ["./src/lib/*.ts"],
      "#controllers/*": ["./src/controllers/*.ts"],
      "#middlewares/*": ["./src/middlewares/*.ts"],
      "#models/*": ["./src/models/*.ts"],
      "#routes/*": ["./src/routes/*.ts"],
      "#db": ["./src/db.ts"]
    },
    "declaration": true,
    "skipLibCheck": true, // 외부 라이브러리 타입 검사 생략해 컴파일 속도 높임 -> 배포 전에 false로 변경
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "index.ts"],
  "exclude": [
    "node_modules", 
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/__tests__/**/*"
  ]
} 